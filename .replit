modules = ["nodejs-24", "dotnet-10.0"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/dotnet-api: .NET API Server"

[[workflows.workflow]]
name = "artifacts/dotnet-api: .NET API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PORT=8099 && export DOTNET_ROOT=/run/current-system/sw/lib/dotnet && cd artifacts/dotnet-api && dotnet run"
waitForPort = 8099

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
