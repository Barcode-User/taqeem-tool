<?xml version="1.0" encoding="UTF-8"?>
<!--
  ملف IIS — يُوجِّه جميع الطلبات إلى خادم Node.js على المنفذ 8080
  يتطلب: IIS URL Rewrite Module + ARR (Application Request Routing)
  تنزيل URL Rewrite: https://www.iis.net/downloads/microsoft/url-rewrite
  تنزيل ARR: https://www.iis.net/downloads/microsoft/application-request-routing
  بعد التثبيت: IIS Manager > ARR > Server Proxy Settings > Enable proxy
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- توجيه كل الطلبات إلى Node.js على المنفذ 8080 -->
        <rule name="NodeJS Proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:8080/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- رفع حد حجم الطلب إلى 200 ميغابايت (لرفع ملفات PDF الكبيرة) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="209715200" />
      </requestFiltering>
    </security>

    <!-- تمرير أخطاء Node.js كما هي بدلاً من صفحات IIS الافتراضية -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>

  <!-- رفع حجم الطلب في ASP.NET أيضاً -->
  <system.web>
    <httpRuntime maxRequestLength="204800" executionTimeout="300" />
  </system.web>

</configuration>
